FROM node:25-slim@sha256:71be4054ee7a5fc8d0b2a66060705988b09a782025d70ba9318b29ff1a931fc0 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app

# Copy package files and install all dependencies (including devDependencies for build)
COPY package*.json ./
RUN npm ci --no-audit --no-fund

# Copy source files needed for Vue build
COPY src ./src
COPY vite.config.ts ./
COPY public ./public

# Build Vue app
RUN npm run build

# Production stage
FROM node:25-alpine@sha256:cf38e1f3c28ac9d81cdc0c51d8220320b3b618780e44ef96a39f76f7dbfef023 AS production

RUN apk add --no-cache curl

WORKDIR /usr/src/app

# Copy package files and install only production dependencies
COPY package*.json ./
RUN npm ci --omit=dev --no-audit --no-fund && \
    npm cache clean --force

# Copy source files and built assets from builder stage
COPY --chown=node:node src ./src
COPY --from=builder --chown=node:node /usr/src/app/public ./public

USER node

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=30s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:80/healthz || exit 1

ENV NODE_ENV=production
ENV APP_ENV=production

CMD ["sh", "-c", "npm run db:migrate:latest && node --no-warnings --max-old-space-size=512 src/server.js"]
