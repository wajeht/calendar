{
    "name": "calendar",
    "version": "0.0.1",
    "private": "true",
    "description": "A web-based calendar application with multiple calendar source support via iCal/WebCal URLs.",
    "keywords": [
        "calendar",
        "fullcalendar",
        "google",
        "ical"
    ],
    "homepage": "https://github.com/wajeht/calendar#readme",
    "bugs": {
        "url": "https://github.com/wajeht/calendar/issues"
    },
    "license": "MIT",
    "author": "wajeht",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wajeht/calendar.git"
    },
    "directories": {
        "doc": "docs"
    },
    "type": "module",
    "main": "server.js",
    "scripts": {
        "start": "node ./src/server.js",
        "dev": "concurrently -n \"VUE,EXPRESS\" -c \"#42b883,#68a063\" \"npm run dev:vue\" \"npm run dev:server\"",
        "dev:serve": "concurrently -n \"VUE,EXPRESS\" -c \"#42b883,#68a063\" \"rm ./public/assets/* && NODE_ENV=development vp build --watch\" \"npm run dev:server\"",
        "dev:server": "npm run db:prepare && node --watch ./src/server.js",
        "dev:vue": "vp dev",
        "build": "rm -rf ./public/assets/* && vp build",
        "preview": "vp preview",
        "update:deps": "npx npm-check -u",
        "check:deps": "npx depcheck",
        "db:prepare": "npm run db:migrate:latest",
        "db:rollback": "knex migrate:rollback --knexfile=./src/db/knexfile.js",
        "db:migrate:make": "knex migrate:make --knexfile=./src/db/knexfile.js",
        "db:migrate:latest": "knex migrate:latest --knexfile=./src/db/knexfile.js",
        "db:migrate:rollback": "knex migrate:rollback --knexfile=./src/db/knexfile.js",
        "db:seed:make": "knex seed:make --knexfile=./src/db/knexfile.js",
        "db:seed:run": "knex seed:run --knexfile=./src/db/knexfile.js",
        "db:reset:password": "sqlite3 src/db/sqlite/db.sqlite \"DELETE FROM settings WHERE key = 'app_password';\"",
        "rmds": "find . -name '.DS_Store' -delete",
        "lint:check": "vp lint",
        "lint": "vp lint --fix",
        "format:check": "vp fmt --check",
        "format": "vp fmt",
        "test": "vp test run",
        "test:watch": "vp test"
    },
    "dependencies": {
        "@fullcalendar/core": "7.0.0-rc.0",
        "@fullcalendar/daygrid": "7.0.0-rc.0",
        "@fullcalendar/icalendar": "7.0.0-rc.0",
        "@fullcalendar/interaction": "7.0.0-rc.0",
        "@fullcalendar/list": "7.0.0-rc.0",
        "@fullcalendar/timegrid": "7.0.0-rc.0",
        "@fullcalendar/vue3": "7.0.0-rc.0",
        "bcryptjs": "3.0.3",
        "better-sqlite3": "12.9.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "2.8.6",
        "express": "5.2.1",
        "express-rate-limit": "8.4.1",
        "helmet": "^8.1.0",
        "ical.js": "^2.2.1",
        "knex": "^3.1.0",
        "node-cron": "^4.2.1",
        "vue": "3.5.32"
    },
    "devDependencies": {
        "@tailwindcss/vite": "4.2.4",
        "@vitejs/plugin-vue": "6.0.6",
        "concurrently": "9.2.1",
        "supertest": "7.2.2",
        "vite-plus": "0.1.20"
    },
    "engines": {
        "node": ">=22",
        "npm": ">=10.0.0"
    },
    "packageManager": "npm@11.13.0"
}
